# Copy this file to .env and fill in your secrets
# .env file will be loaded automatically at script startup
# DO NOT commit the actual .env file to version control

# ═══════════════════════════════════════════════════════════════════════
# SECURITY STRATEGY FOR THIS REPO
# ═══════════════════════════════════════════════════════════════════════
#
# LOCAL DEVELOPMENT → Use .env file (this file):
#   1. Copy this template: cp .env.template .env
#   2. Fill in ALL required and optional values below
#   3. Script loads from .env automatically at startup
#   4. .env is in .gitignore — never committed to version control
#
# PRODUCTION / CI-CD / AZURE ENVIRONMENTS → Use Azure Key Vault:
#   1. Don't create .env file (skip or delete)
#   2. Use Azure Key Vault instead for ADO_PAT
#   3. Script falls back to Key Vault automatically for ADO_PAT
#   4. Authenticate via: az login (or use Managed Identity in Azure)
#   5. Still use .env for non-secret config if needed
#
# PAT RESOLUTION PRIORITY (Highest to Lowest):
#   1. --pat command-line argument
#   2. ADO_PAT environment variable (from .env or shell export)
#   3. Azure Key Vault (automatic fallback for production)
#
# ═══════════════════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════════════════════
# REQUIRED SECRETS
# ══════════════════════════════════════════════════════════════════════════

# Azure DevOps Personal Access Token (REQUIRED)
# Get your PAT from: https://dev.azure.com/domoreexp/MSTeams/_usersSettings/tokens
# Create a token with "Work Items (read)" scope (or "read & write" for full access)
ADO_PAT="VSO-PAT"


# ══════════════════════════════════════════════════════════════════════════
# AZURE DEVOPS CONFIGURATION (customize if using different org/project)
# ══════════════════════════════════════════════════════════════════════════

# ADO Organization URL
ADO_ORG_URL=https://domoreexp.visualstudio.com

# ADO Project name
ADO_PROJECT=MSTeams


# ══════════════════════════════════════════════════════════════════════════
# AZURE KEY VAULT CONFIGURATION (for production/CI-CD)
# ══════════════════════════════════════════════════════════════════════════

# Key Vault URL (where PAT secret is stored)
# Modify only if using a different Key Vault
KEY_VAULT_URL=https://kv-msteamsappcert-prod.vault.azure.net/

# Key Vault secret name (where ADO PAT is stored)
# Modify only if using a different secret name
PAT_SECRET_NAME=VSO-PAT


# ══════════════════════════════════════════════════════════════════════════
# TEAMS & APP CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════

# Teams URL (default provided by script, override here if needed)
TEAMS_URL=https://teams.microsoft.com/v2/

# SMP API Base URL (for fetching app package details)
# Default: https://msteamspmewebapi.azurewebsites.net
SMP_API_URL=https://msteamspmewebapi.azurewebsites.net


# ══════════════════════════════════════════════════════════════════════════
# MAGENTIC UI SERVER CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════

# Magentic UI server URL
# Change this if your Magentic UI server runs on a different host/port
# Default: http://localhost:8081
MAGENTIC_SERVER_URL=http://localhost:8081


# ══════════════════════════════════════════════════════════════════════════
# UPLOAD & USER CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════

# Default user ID/email for plan uploads (optional)
# Set this to skip the --upload-user prompt
# If not set, script will prompt for user email when --upload is used
MAGENTIC_USER_ID=your_email@contoso.com
